{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "amd-MI300A-env",
            "displayName": "AMD MI300A environment settings",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_HIP_ARCHITECTURES": "gfx942"
            },
            "condition": {
                "type": "anyOf",
                "conditions": [
                    {
                        "type": "matches",
                        "string": "$env{HOSTNAME}",
                        "regex": "^viper[0-9]+$"
                    },
                    {
                        "type": "equals",
                        "lhs": "$env{AMD_ARCHITECTURE}",
                        "rhs": "MI300A"
                    }
                ]
            }
        },
        {
            "name": "nvidia-A100-env",
            "displayName": "NVIDIA A100 environment settings",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CUDA_ARCHITECTURES": "80"
            },
            "condition": {
                "type": "anyOf",
                "conditions": [
                    {
                        "type": "matches",
                        "string": "$env{HOSTNAME}",
                        "regex": "^raven[0-9]+$"
                    },
                    {
                        "type": "equals",
                        "lhs": "$env{NVIDIA_ARCHITECTURE}",
                        "rhs": "A100"
                    }
                ]
            }
        },
        {
            "name": "gempic-cuda-cache-vars",
            "displayName": "GEMPIC Cache Variables for CUDA",
            "hidden": true,
            "cacheVariables": {
                "GEMPIC_USE_CUDA": "On",
                "GEMPIC_USE_HIP": "Off"
            }
        },
        {
            "name": "gempic-cpu-cache-vars",
            "displayName": "GEMPIC Cache Variables CPU",
            "hidden": true,
            "cacheVariables": {
                "GEMPIC_USE_CUDA": "Off",
                "GEMPIC_USE_HIP": "Off"
            }
        },
        {
            "name": "gempic-hip-cache-vars",
            "displayName": "GEMPIC Cache Variables for HIP",
            "hidden": true,
            "cacheVariables": {
                "GEMPIC_USE_CUDA": "Off",
                "GEMPIC_USE_HIP": "On"
            }
        },
        {
            "name": "mpi-compiler",
            "displayName": "MPI Compiler",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "mpicxx",
                "CMAKE_C_COMPILER": "mpicc",
                "CMAKE_CUDA_HOST_COMPILER": "mpicxx"
            }
        },
        {
            "name": "impi-compiler",
            "displayName": "Intel MPI Compiler",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "mpiicpx",
                "CMAKE_C_COMPILER": "mpiicx",
                "CMAKE_CUDA_HOST_COMPILER": "mpiicpx"
            }
        },
        {
            "name": "mpcdf-viper-3D",
            "displayName": "GPU settings for Viper 3D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits" : [
                "amd-MI300A-env",
                "mpi-compiler",
                "gempic-hip-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "3"
            }
        },
        {
            "name": "mpcdf-viper-2D",
            "displayName": "GPU settings for Viper 2D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits" : [
                "amd-MI300A-env",
                "mpi-compiler",
                "gempic-hip-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "2"
            }
        },
        {
            "name": "mpcdf-viper-1D",
            "displayName": "GPU settings for Viper 1D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits" : [
                "amd-MI300A-env",
                "mpi-compiler",
                "gempic-hip-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "1"
            }
        },
        {
            "name": "mpcdf-cloud-cuda",
            "displayName": "GPU settings for MPCDF gitlab cloud CUDA runner",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "nvidia-A100-env",
                "mpi-compiler",
                "gempic-cuda-cache-vars"
            ],
            "condition": {
                "type": "equals",
                "lhs": "$env{NVIDIA_ARCHITECTURE}",
                "rhs": "A100"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "mpcdf-raven-3D",
            "displayName": "GPU settings for Raven 3D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "nvidia-A100-env",
                "mpi-compiler",
                "gempic-cuda-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "3"
            }
        },
        {
            "name": "mpcdf-raven-2D",
            "displayName": "GPU settings for Raven 2D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "nvidia-A100-env",
                "mpi-compiler",
                "gempic-cuda-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "2"
            }
        },
        {
            "name": "mpcdf-raven-1D",
            "displayName": "GPU settings for Raven 1D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "nvidia-A100-env",
                "mpi-compiler",
                "gempic-cuda-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "1"
            }
        },
        {
            "name": "cpu-debug-3D",
            "displayName": "CPU debug 3D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "3",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-debug-2D",
            "displayName": "CPU debug 2D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "2",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "intel-cpu-debug-2D",
            "displayName": "intel-CPU debug 2D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "impi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "2",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-debug-1D",
            "displayName": "CPU debug 1D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "1",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-release-3D",
            "displayName": "CPU release 3D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "3"
            }
        },
        {
            "name": "cpu-release-2D",
            "displayName": "CPU release 2D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "2"
            }
        },
        {
            "name": "cpu-release-1D",
            "displayName": "CPU release 1D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "1"
            }
        },
        {
            "name": "documentation",
            "displayName": "Build only GEMPIC documentation",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
              "GEMPIC_BUILD_ONLY_DOCUMENTATION": "ON"
            }
        }
    ]
}
