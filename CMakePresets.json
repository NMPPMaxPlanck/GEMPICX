{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 22,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "raven-env",
            "displayName": "Raven environment settings",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CUDA_ARCHITECTURES": "80"
            }
        },
        {
            "name": "gempic-gpu-cache-vars",
            "displayName": "GEMPIC Cache Variables GPU",
            "hidden": true,
            "cacheVariables": {
                "GEMPIC_USE_CUDA": "On"
            }
        },
        {
            "name": "gempic-cpu-cache-vars",
            "displayName": "GEMPIC Cache Variables CPU",
            "hidden": true,
            "cacheVariables": {
                "GEMPIC_USE_CUDA": "Off"
            }
        },
        {
            "name": "mpi-compiler",
            "displayName": "MPI Compiler",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "mpicxx",
                "CMAKE_C_COMPILER": "mpicc",
                "CMAKE_CUDA_HOST_COMPILER": "mpicxx"
            }
        },
        {
            "name": "mpcdf-gpu-3D",
            "displayName": "GPU settings for Raven 3D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "raven-env",
                "mpi-compiler",
                "gempic-gpu-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "3"
            }
        },
        {
            "name": "mpcdf-gpu-2D",
            "displayName": "GPU settings for Raven 2D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "raven-env",
                "mpi-compiler",
                "gempic-gpu-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "2"
            }
        },
        {
            "name": "mpcdf-gpu-1D",
            "displayName": "GPU settings for Raven 1D",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "raven-env",
                "mpi-compiler",
                "gempic-gpu-cache-vars"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "1"
            }
        },
        {
            "name": "cpu-debug-3D",
            "displayName": "CPU debug 3D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "3",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-debug-2D",
            "displayName": "CPU debug 2D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "2",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-debug-1D",
            "displayName": "CPU debug 1D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "AMReX_SPACEDIM": "1",
                "GEMPIC_USE_LTO": "OFF"
            }
        },
        {
            "name": "cpu-release-3D",
            "displayName": "CPU release 3D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "3"
            }
        },
        {
            "name": "cpu-release-2D",
            "displayName": "CPU release 2D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "2"
            }
        },
        {
            "name": "cpu-release-1D",
            "displayName": "CPU release 1D settings",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "inherits": [
                "gempic-cpu-cache-vars",
                "mpi-compiler"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "AMReX_SPACEDIM": "1"
            }
        }
    ]
}
