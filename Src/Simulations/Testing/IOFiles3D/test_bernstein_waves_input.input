# General setting
simName = "test_bernstein_waves"

# Grid parameters
nCellVector = 128 8 8
maxGridSizeVector = 32 8 8
isPeriodicVector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
Particle.speciesNames = ions
Particle.ions.nPartPerCell = 10 # number of Particles per cell
Particle.ions.charge = 1.0 # vector (one entry per species)
Particle.ions.mass = 1.0 # vector (one entry per species)
Particle.ions.density = "1.0 + 0.01 * cos(kvarx * x)"
Particle.ions.numGaussians = 1

# Gaussian parameters
Particle.ions.G0.vMean = 0.0 0.0 0.0
Particle.ions.G0.vThermal = 1 1 1
Particle.ions.G0.vWeight = 1.0

# wave vector
k = 1 1 0.3

# Simulation parameters
TimeLoop.nSteps = 50000
TimeLoop.dt = 0.02

# Function parameters
Function.Bx = "0.0"
Function.By = "0.0"
Function.Bz = "1.0"

# Filter
Filter.enable = 1
Filter.npassEachDir = 3 3 3

# Full Diagnostics
FullDiagnostics.enable = 1 # 1 for true, 0 for false
FullDiagnostics.groupNames = part_test Ez_raw plots 

FullDiagnostics.part_test.varNames = particles # default name for a particle group
FullDiagnostics.part_test.functor = raw

FullDiagnostics.plots.varNames = Ey Ez Bx
FullDiagnostics.plots.functor = CellCenter

FullDiagnostics.Ez_raw.varNames = Ez
FullDiagnostics.Ez_raw.saveInterval = 50
FullDiagnostics.Ez_raw.functor = raw

# Reduced Diagnostics
ReducedDiagnostics.enable = 1 # 1 for true, 0 for false
ReducedDiagnostics.groupNames = Part FieldEnergies GaussErr
ReducedDiagnostics.saveInterval = 5 # saveInterval for all groupings not specifying their own

ReducedDiagnostics.FieldEnergies.types = ElecFieldEnergy MagFieldEnergy

ReducedDiagnostics.Part.types = Particle

ReducedDiagnostics.GaussErr.types = GaussError
