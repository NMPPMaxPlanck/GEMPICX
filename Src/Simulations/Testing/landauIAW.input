# General setting
simName = "test_bernstein_waves"

# Grid parameters
nCellVector = 32 8 8
maxGridSizeVector = 8 8 8
isPeriodicVector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
Particle.speciesNames = ions
Particle.ions.nPartPerCell = 5000 # number of Particles per cell
Particle.ions.charge = 1.0 # vector (one entry per species)
Particle.ions.mass = 1.0 # vector (one entry per species)
Particle.ions.density = "1.0 + 0.04 * cos(kvarx * x)"
Particle.ions.numGaussians = 1

# Gaussian parameters
Particle.ions.G0.vMean = 0.0 0.0 0.0
Particle.ions.G0.vThermal = 1 1 1
Particle.ions.G0.vWeight = 1.0

# wave vector
k = 1.0 1.0 1.0

# Simulation parameters
TimeLoop.nSteps = 500
TimeLoop.dt = 0.02
Sim.Te = 10

# Diagnostics
#Full Diagnostics 
FullDiagnostics.enable = 1 # 1 for true, 0 for false 
FullDiagnostics.groupNames = part field 
FullDiagnostics.part.varNames = ions
FullDiagnostics.part.saveInterval = 1000
FullDiagnostics.field.varNames = rho Ex Ey Ez Dy Bz phi 
FullDiagnostics.field.functor = CellCenter 
FullDiagnostics.field.saveInterval = 1000

# Reduced Diagnostics 
ReducedDiagnostics.groupNames = PartDiag FieldDiag #GaussErr 
ReducedDiagnostics.saveInterval = 1 # Default saveInterval for all reduced diagnostic groups
ReducedDiagnostics.FieldDiag.types = ElecFieldEnergy MagFieldEnergy 
ReducedDiagnostics.PartDiag.types = Particle 
ReducedDiagnostics.GaussErr.types = GaussError

# Function parameters
Function.Bx = "0.0"
Function.By = "0.0"
Function.Bz = "0.0" 
