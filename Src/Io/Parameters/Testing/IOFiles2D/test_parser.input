# General setting
simName = "test_parser"

# Grid parameters
nCellVector = 24 8 8
maxGridSizeVector = 4 4 4
domainLo = 0.0 0.25 0.75 # low end of computational domain (3D)
domainHi = 1.5 2.5 3.5 # high end of computational domain (3D)
isPeriodicVector = 0 1 1 # 1 -> periodic, 0 -> else
# wave vector
k= 0.2 0.3 0.4 # 1.25 for Weibel, 0.5 for Landau

# Time discretisation
nSteps = 50000
dt = 0.1
propagator = 0 
strang_order = 2

# Tolerances for iterative solver (if needed by the chosen propagator)
toleranceParticles = 1.e-10
# For multigrid solver
max_coarsening_level = 30

# Particle parameters
Particle.speciesNames = electrons ions
Particle.electrons.nPartPerCell = 100 
Particle.electrons.charge = -1.0
Particle.electrons.mass = 1.0
Particle.ions.nPartPerCell = 100 
Particle.ions.charge = 1.0
Particle.ions.mass = 1.0

# Gaussian parameters
Particle.electrons.density = "1.0 +  cos(kvarx * x) + sin(kvary * y) + cos(2*kvarz *z)"
Particle.electrons.numGaussians = 2
Particle.electrons.G0.vMean = 0 0 0
Particle.electrons.G0.vThermal = 1.0 1.0 1.0
Particle.electrons.G0.vWeight = 0.75
Particle.electrons.G1.vMean = -2.4 0 0
Particle.electrons.G1.vThermal = 1.0 1.0 1.0
Particle.electrons.G1.vWeight = 0.25

Particle.ions.density = "1.0 +  0.2*cos(kvarx * x)"
Particle.ions.numGaussians = 1
Particle.ions.G0.vMean = 2.4 0 0
Particle.ions.G0.vThermal = 1.0 1.0 1.0
Particle.ions.G0.vWeight = 1.0

# Diagnostics
saveFields = 100001 
saveParticles = 100001 
save_checkpoint = 100001

# Function parameters
Bx = "sin (kvarx * x + kvary * y + kvarz * z - t)"
By = "cos (kvarx * x + kvary * y + kvarz * z - t)"
Bz = "1e-3 * cos(kvarx * x)"
Ex = "sin (kvarx * x + kvary * y + kvarz * z - t)"
Ey = "cos (kvarx * x + kvary * y + kvarz * z - t)"
Ez = "1e-3 * cos(kvarx * x)"
phi = "4 * 0.5 * cos(0.5 * x)"
rho = "1 + 0.1 * cos(0.5 * x)"

# Restart parameters
restart = 0
checkpoint_file = "Checkpoint/Weibel_2"
curr_step = 100

# Scaling parameters
curlB_scaling = 1.0
epref_ep0 = 1.0
energy_b_scaling = 1.0


