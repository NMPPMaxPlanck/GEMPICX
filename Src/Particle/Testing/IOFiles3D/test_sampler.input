# General setting
simName = "sampler_ctest"

# Grid parameters
nCellVector = 4 4 4
maxGridSizeVector = 32 8 8 # DEFAULT from old params class
isPeriodicVector = 1 1 1 # 1 -> periodic, 0 -> else # DEFAULT from old params class

# Particle parameters
Particle.speciesNames = ions1 ions2 ions3

Particle.ions1.sampler = Cellwise
Particle.ions1.nPartPerCell = 1000 # number of Particles per cell
Particle.ions1.charge = 1.0 # vector (one entry per species)
Particle.ions1.mass = 1.0 # vector (one entry per species)
Particle.ions1.density = "1 + 0.5 * sin(kvarx*x + kvary*y + kvarz*z)"

Particle.ions2.sampler = PseudoRandom
Particle.ions2.nPartPerCell = 1000 # number of Particles per cell
Particle.ions2.charge = 1.0 # vector (one entry per species)
Particle.ions2.mass = 1.0 # vector (one entry per species)
Particle.ions2.density = "1 + 0.5 * sin(kvarx*x + kvary*y + kvarz*z)"

Particle.ions3.sampler = FullDomainGpu
Particle.ions3.nPartPerCell = 1000 # number of Particles per cell
Particle.ions3.charge = 1.0 # vector (one entry per species)
Particle.ions3.mass = 1.0 # vector (one entry per species)
Particle.ions3.density = "1 + 0.5 * sin(kvarx*x + kvary*y + kvarz*z)"

# Gaussian parameters
Particle.ions1.numGaussians = 2

Particle.ions1.G0.vMean = 0.0 0.0 0.0
Particle.ions1.G0.vThermal = 2.0 2.0 2.0
Particle.ions1.G0.vWeight = 0.75

Particle.ions1.G1.vMean = 2.0 2.0 2.0
Particle.ions1.G1.vThermal = 1.0 1.0 1.0
Particle.ions1.G1.vWeight = 0.25


Particle.ions2.numGaussians = 2

Particle.ions2.G0.vMean = 0.0 0.0 0.0
Particle.ions2.G0.vThermal = 2.0 2.0 2.0
Particle.ions2.G0.vWeight = 0.75

Particle.ions2.G1.vMean = 2.0 2.0 2.0
Particle.ions2.G1.vThermal = 1.0 1.0 1.0
Particle.ions2.G1.vWeight = 0.25


Particle.ions3.numGaussians = 2

Particle.ions3.G0.vMean = 0.0 0.0 0.0
Particle.ions3.G0.vThermal = 2.0 2.0 2.0
Particle.ions3.G0.vWeight = 0.75

Particle.ions3.G1.vMean = 2.0 2.0 2.0
Particle.ions3.G1.vThermal = 1.0 1.0 1.0
Particle.ions3.G1.vWeight = 0.25