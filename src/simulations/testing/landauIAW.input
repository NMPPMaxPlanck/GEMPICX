# General setting
sim_name = "test_bernstein_waves"

# Grid parameters
n_cell_vector = 32 8 8
max_grid_size_vector = 8 8 8
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
particle.species0.n_part_per_cell = 5000 # number of particles per cell
particle.species0.charge = 1.0 # vector (one entry per species)
particle.species0.mass = 1.0 # vector (one entry per species)
particle.species0.density = "1.0 + 0.04 * cos(kvarx * x)"
particle.species0.num_gaussians = 1

# Gaussian parameters
particle.species0.vMean_g0 = 0.0 0.0 0.0
particle.species0.vThermal_g0 = 1 1 1
particle.species0.vWeight_g0 = 1.0

# wave vector
k = 1.0 1.0 1.0

# Simulation parameters
time_loop.n_steps = 500
time_loop.dt = 0.02
sim.Te = 10

# Diagnostics
#Full Diagnostics 
fullDiagnostics.enable = 1 # 1 for true, 0 for false 
fullDiagnostics.group_names = part field 
fullDiagnostics.part.var_names = ions
fullDiagnostics.part.save_interval = 1000
fullDiagnostics.field.var_names = rho Ex Ey Ez Dy Bz phi 
fullDiagnostics.field.functor = CellCenter 
fullDiagnostics.field.save_interval = 1000

# Reduced Diagnostics 
reducedDiagnostics.group_names = PartDiag FieldDiag #GaussErr 
reducedDiagnostics.save_interval = 1 # Default save_interval for all reduced diagnostic groups
reducedDiagnostics.FieldDiag.types = ElecFieldEnergy MagFieldEnergy 
reducedDiagnostics.PartDiag.types = Particle 
reducedDiagnostics.GaussErr.types = GaussError

# Function parameters
function.Bx = "0.0"
function.By = "0.0"
function.Bz = "0.0" 
