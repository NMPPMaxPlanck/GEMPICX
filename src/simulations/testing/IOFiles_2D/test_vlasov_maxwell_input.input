# General setting
sim_name = "test_vlasov_maxwell_input"

# Grid parameters
n_cell_vector = 24 8 8
max_grid_size_vector = 4 4 4
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
species0.n_part_per_cell = 100 # number of particles per cell
species0.charge = -1.0 # vector (one entry per species)
species0.mass = 1.0 # vector (one entry per species)
species0.density = "1.0 + 0.0 * cos(kvarx * x)"
species0.num_gaussians = 1

# Gaussian parameters
species0.vMean_g0 = 0.0 0.0 0.0
species0.vThermal_g0 = 0.01414213562 0.04898979486 0.04898979486 # 0.02/sqrt(2) and sqrt(12)*0.02/sqrt(2)
species0.vWeight_g0 = 1.0

# wave vector
k = 1.25 1.25 1.25 # 1.25 for Weibel, 0.5 for Landau
 
# Simulation parameters
n_steps = 5
dt = 0.02
strang_order = 2
propagator = 3
freq_x = 100001 
freq_v = 100001 
freq_slice = 100001 

# Function parameters
Bx = "0.0"
By = "0.0"
Bz = "1e-3 * cos(kvarx * x)"
phi = "4 * 0.5 * cos(0.5 * x)"
rho = "1"

# Tolerances for iterative solver (if needed by the chosen propagator)
tolerance_particles = 1.e-10
# For multigrid solver
max_coarsening_level = 30

# Restart parameters
restart = 0
checkpoint_file = "Checkpoint/Test_Weibel_2_"
curr_step = 4

# Scaling parameters
curlB_scaling = 1.0
epref_ep0 = 1.0
energy_b_scaling = 1.0
