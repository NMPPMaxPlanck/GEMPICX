# General setting
sim_name = "test_bernstein_waves"

# Grid parameters
n_cell_vector = 128 8 8
max_grid_size_vector = 32 8 8
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
particle.species0.n_part_per_cell = 10 # number of particles per cell
particle.species0.charge = 1.0 # vector (one entry per species)
particle.species0.mass = 1.0 # vector (one entry per species)
particle.species0.density = "1.0 + 0.01 * cos(kvarx * x)"
particle.species0.num_gaussians = 1

# Gaussian parameters
particle.species0.vMean_g0 = 0.0 0.0 0.0
particle.species0.vThermal_g0 = 1 1 1
particle.species0.vWeight_g0 = 1.0

# wave vector
k = 1 1 0.3

# Simulation parameters
time_loop.n_steps = 50000
time_loop.dt = 0.02
time_loop.save_fields = 1
time_loop.save_particles = 1

# Function parameters
function.Bx = "0.0"
function.By = "0.0"
function.Bz = "1.0"

# filter
filter.use_filter = 1
filter.filter_npass_each_dir = 3 3 3

# Full Diagnostics
fullDiagnostics.enable = 1 # 1 for true, 0 for false
fulldiagnostics.group_names = part_test Ez_raw plots 

fullDiagnostics.part_test.var_names = particles
fullDiagnostics.part_test.functor = raw

fullDiagnostics.plots.var_names = Ey Ez Bx
fullDiagnostics.plots.functor = CellCenter

fullDiagnostics.Ez_raw.var_names = Ez
fullDiagnostics.Ez_raw.save_interval = 50
fullDiagnostics.Ez_raw.functor = raw

# Reduced Diagnostics
reducedDiagnostics.enable = 1 # 1 for true, 0 for false
reducedDiagnostics.group_names = Part FieldEnergies GaussErr
reducedDiagnostics.save_interval = 5 # save_interval for all groupings not specifying their own

reducedDiagnostics.FieldEnergies.types = ElecFieldEnergy MagFieldEnergy

reducedDiagnostics.Part.types = Particle

reducedDiagnostics.GaussErr.types = GaussError
