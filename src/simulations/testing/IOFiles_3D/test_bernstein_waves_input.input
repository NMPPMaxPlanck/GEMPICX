# General setting
sim_name = "test_bernstein_waves"

# Grid parameters
n_cell_vector = 128 8 8
max_grid_size_vector = 32 8 8
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
species0.n_part_per_cell = 1000 # number of particles per cell
species0.charge = 1.0 # vector (one entry per species)
species0.mass = 1.0 # vector (one entry per species)
species0.density = "1.0 + 0.01 * cos(kvarx * x)"
species0.num_gaussians = 1

# Gaussian parameters
species0.vMean_g0 = 0.0 0.0 0.0
species0.vThermal_g0 = 1 1 1
species0.vWeight_g0 = 1.0

# wave vector
k = 1 1 0.3

# Simulation parameters
n_steps = 50000
dt = 0.02
save_fields = 1
save_particles = 1

# Function parameters
Bx = "0.0"
By = "0.0"
Bz = "1.0"
