# General setting
sim_name = "sampler_ctest"

# Grid parameters
n_cell_vector = 4 4 4
max_grid_size_vector = 32 8 8 # DEFAULT from old params class
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else # DEFAULT from old params class

# Particle parameters
particle.species0.n_part_per_cell = 1000 # number of particles per cell
particle.species0.charge = 1.0 # vector (one entry per species)
particle.species0.mass = 1.0 # vector (one entry per species)
particle.species0.density = "1 + 0.5 * sin(kvarx*x + kvary*y + kvarz*z)"

# Gaussian parameters
particle.species0.num_gaussians = 2

particle.species0.vMean_g0 = 0.0 0.0 0.0
particle.species0.vThermal_g0 = 2.0 2.0 2.0
particle.species0.vWeight_g0 = 0.75

particle.species0.vMean_g1 = 2.0 2.0 2.0
particle.species0.vThermal_g1 = 1.0 1.0 1.0
particle.species0.vWeight_g1 = 0.25
