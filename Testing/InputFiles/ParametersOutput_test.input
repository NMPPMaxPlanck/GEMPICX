# General setting
simName = "ParametersOutput_test"
outputFile = "ParametersOutput_test.output"

# Grid parameters
ComputationalDomain.nCell = 128 8 8
ComputationalDomain.maxGridSize = 32 8 8
ComputationalDomain.isPeriodic = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
Particle.speciesNames = ions
Particle.sampler = PseudoRandom
Particle.ions.nPartPerCell = 10 # number of Particles per cell
Particle.ions.charge = 1.0 # vector (one entry per species)
Particle.ions.mass = 1.0 # vector (one entry per species)
Particle.ions.density = "1.0 + 0.01 * cos(kvarx * x)"
Particle.ions.numGaussians = 1

# Gaussian parameters
Particle.ions.G0.vMean = 0.0 0.0 0.0
Particle.ions.G0.vThermal = 1 1 1
Particle.ions.G0.vWeight = 1.0

# wave vector
k = 1 1 0.3

# Simulation parameters
TimeLoop.nSteps = 5
TimeLoop.dt = 0.02
TimeLoop.saveFields = 1
TimeLoop.saveParticles = 1

# Function parameters
Function.Bx = "0.0"
Function.By = "0.0"
Function.Bz = "1.0"
