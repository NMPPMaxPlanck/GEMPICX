# Grid parameters
nCellVector = 64 8 8
maxGridSizeVector = 8 8 8
isPeriodicVector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
Particle.speciesNames = ions
Particle.ions.nPartPerCell = 10 # number of Particles per cell
Particle.ions.charge = 1.0 # vector (one entry per species)
Particle.ions.mass = 1.0 # vector (one entry per species)
Particle.ions.density = "1.0" # + 0.02 * cos(kvarx * x)"
Particle.ions.numGaussians = 1

# Gaussian parameters
Particle.ions.G0.vMean = 0.0 0.0 0.0
Particle.ions.G0.vThermal = 1 1 1
Particle.ions.G0.vWeight = 1.0

# wave vector
k = 0.3 0.3 0.004166666666666667

#Full Diagnostics
FullDiagnostics.enable = 1 # 1 for true, 0 for false
FullDiagnostics.groupNames = part field
FullDiagnostics.field.varNames = rho Ex Ey Ez Bx By Bz phi
FullDiagnostics.field.outputProcessor = CellCenter
FullDiagnostics.field.saveInterval = 1
FullDiagnostics.part.saveInterval = 1

# Function parameters
Function.rho = "1.0"
Function.phi = "1.0"
Function.Ex = "1.0"
Function.Ey = "1.0"
Function.Ez = "1.0"
Function.Bx = "1.0"
Function.By = "1.0"
Function.Bz = "1.0"
