# General setting
sim_name = "LHW_test"

# Grid parameters
n_cell_vector = 20 20 20
max_grid_size = 4
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
n_part_per_cell = 1000 # number of particles per cell
charge = -1.0 1.0 # vector (one entry per species)
mass = 1.0 1836.0 # vector (one entry per species)
num_gaussians = 1


# wave vector
kx = 2.094 # 1.25 for Weibel, 0.5 for Landau
ky = 2.094
kz = 0.02094

# Simulation parameters
n_steps = 10
dt = 0.0420
freq_x = 1
freq_v = 1 
freq_slice = 1 

# Function parameters
WF = "1.0 + 0.10 * cos(kvarx * x+kvarz*z)"
Bx = "0.0"
By = "0.0"
Bz = "1.1893"
phi = "0.10 * cos(kvarx * x+kvarz*z)"

# Choose the propagator: 0 - Boris-FD, 1 - HS-FEM
propagator = 2

# Tolerances for iterative solver (if needed by the chosen propagator)
tolerance_particles = 1.e-10

# Restart parameters
restart = 0
checkpoint_file = "Checkpoint/Weibel_2"
curr_step = 100
