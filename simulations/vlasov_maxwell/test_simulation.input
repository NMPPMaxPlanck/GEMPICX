# General setting
sim_name = "Weibel"

# Grid parameters
n_cell_vector = 12 8 8
max_grid_size_vector = 4 4 4
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else
# wave vector
k = 1.25 1.25 1.25 # 1.25 for Weibel, 0.5 for Landau

# Particle parameters
species0.n_part_per_cell = 2000 # number of particles per cell
species0.charge = -1.0 # vector (one entry per species)
species0.mass = 1.0 # vector (one entry per species)

# Gaussian parameters
species0.num_gaussians = 1
species0.vMean_g0 = 0 0 0
species0.vThermal_g0 = 0.014142135623730949 0.04898979485566356 0.04898979485566356
species0.vWeight_g0 = 1
species0.WF = "1.0 + 0.0 * cos(kvarx * x)"   # initial particle density

# Simulation parameters
n_steps = 10
dt = 0.02
freq_x = 100001 
freq_v = 100001 
freq_slice = 100001 
propagator = 3 #  0 - Boris-FD, 1 - HS-FEM, 2 - HS-FEM-ALL, 3 - HS-FEM-ZIGZAG
tolerance_particles = 1.e-10 # Tolerances for iterative solver (if needed by the chosen propagator)

# Function parameters
Bx = "0.0"
By = "0.0"
Bz = "1e-3 * cos(kvarx * x)"
phi = "4 * 0.5 * cos(0.5 * x)"

# Restart parameters
restart = 0
checkpoint_file = "Checkpoint/Test_Weibel_2_"
curr_step = 4

