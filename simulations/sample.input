# General setting
sim_name = "Weibel" # (string) name to include in saved files

# Grid parameters
n_cell_vector = 24 8 8       # (integers) GEMPIC_DIM many: each describes the number of cells in each direction
max_grid_size_vector = 4 4 4 # (integers) biggest possible size of a tile in each dim for dividing grid into tiles
is_periodic_vector = 1 1 1   # (integers) GEMPIC_DIM many, one for each direction: 1 -> periodic, 0 -> else
# wave vector
k = 1.25 1.25 1.25   # (double) e.g.  for standard test cases 1.25 (Weibel), 0.5 (Landau damping)
# computational domain (not used in periodic directions -> [0,2pi/k])
domain_lo = 0.0 0.0 0.0 # low end of computational domain (3D)
domain_hi = 1.5 1.5 1.5 # high end of computational domain (3D)

# Particle parameters (here 1 species, 1 gaussian)
species0.n_part_per_cell = 100   # (integer) number of particles per cell
species0.charge = -1.0           # (doubles) GEMPIC_NUMSPEC many, one entry per species
species0.mass = 1.0              # (doubles) GEMPIC_NUMSPEC many, one entry per species

# Gaussian parameters 
species0.num_gaussians = 1
species0.vMean_g0 = 0 0 0
species0.vThermal_g0 = 0.014142135623730949 0.04898979485566356 0.04898979485566356
species0.vWeight_g0 = 1

WF = "1.0 + 0.0 * cos(kvarx * x)"   # (string) function: initial particle density

# Simulation parameters
n_steps = 100000    # (integer) number of simulation steps
dt = 0.02           # (double) size of time step
freq_x = 100001     # (integer) how often should the x-Coordinates of particles be saved into a file
freq_v = 100001     # (integer) how often should the v-Coordinates of particles be saved into a file
freq_slice = 100001 # (integer) how often should slices of the fields be saved into a file
propagator = 0  #  0 - Boris-FD, 1 - HS-FEM, 2 - HS-FEM-ALL, 3 - HS-FEM-ZIGZAG
tolerance_particles = 1.e-10 # Tolerances for iterative solver (if needed by the chosen propagator)

# Initial values of fields 
Bx = "0.0"                          # (string) function: initial Bx-field
By = "0.0"                          # (string) function: initial By-field
Bz = "1e-3 * cos(kvar * x)"         # (string) function: initial Bz-field
phi = "4 * 0.5 * cos(0.5 * x)"      # (string) function: initial phi

# Restart parameters
restart = 0                                     # (integer) 1 to restart simulation from checkpoint, 0 else
checkpoint_file = "Checkpoint/Weibel_2"         # (string) folder containing checkpoint data minus the step
curr_step = 4                                   # (integer) stepnumber of the checkpointfile that should be read in
