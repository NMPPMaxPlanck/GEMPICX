# General setting
utest.keep_parameters = 1
sim_name = "GTest"

# Grid parameters
n_cell_vector = 128 8 8
max_grid_size_vector = 32 8 8
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
particle.species0.n_part_per_cell = 10 # number of particles per cell
particle.species0.charge = 1.0 # vector (one entry per species)
particle.species0.mass = 1.0 # vector (one entry per species)
particle.species0.density = "1.0 + 0.01 * cos(kvarx * x)"
particle.species0.num_gaussians = 1

# Gaussian parameters
particle.species0.vMean_g0 = 0.0 0.0 0.0
particle.species0.vThermal_g0 = 1 1 1
particle.species0.vWeight_g0 = 1.0

# wave vector
k = 1 1 0.3

# Simulation parameters
time_loop.n_steps = 50000
time_loop.dt = 0.02
time_loop.save_fields = 1
time_loop.save_particles = 1

# Function parameters
function.Bx = "0.0"
function.By = "0.0"
function.Bz = "1.0"
