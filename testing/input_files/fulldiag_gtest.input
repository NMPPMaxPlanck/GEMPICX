# Grid parameters
n_cell_vector = 64 8 8
max_grid_size_vector = 8 8 8
is_periodic_vector = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
particle.species0.n_part_per_cell = 10 # number of particles per cell
particle.species0.charge = 1.0 # vector (one entry per species)
particle.species0.mass = 1.0 # vector (one entry per species)
particle.species0.density = "1.0" # + 0.02 * cos(kvarx * x)"
particle.species0.num_gaussians = 1

# Gaussian parameters
particle.species0.vMean_g0 = 0.0 0.0 0.0
particle.species0.vThermal_g0 = 1 1 1
particle.species0.vWeight_g0 = 1.0

# wave vector
k = 0.3 0.3 0.004166666666666667

#Full Diagnostics
fulldiagnostics.enable = 1 # 1 for true, 0 for false
fulldiagnostics.diags_names = part field
part.type = particle
field.type = field
field.var_names = rho Ex Ey Ez Bx By Bz phi
field.functor = CellCenter
field.save_interval = 1
part.save_interval = 1

# Function parameters
function.rho = "1.0"
function.phi = "1.0"
function.Ex = "1.0"
function.Ey = "1.0"
function.Ez = "1.0"
function.Bx = "1.0"
function.By = "1.0"
function.Bz = "1.0"
