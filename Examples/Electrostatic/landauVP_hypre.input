#hypre.bamg_smooth_num_levels = 100 # integer type
hypre.bamg_ilu_max_iter = 200 # integer type
hypre.bamg_ilu_max_row_nnz = 200 # integer type
hypre.bamg_ilu_drop_tol = 1.e-10

### options for hypre.bamg_smooth_type = 9
