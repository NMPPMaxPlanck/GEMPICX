# General setting
Sim.Type = "VlasovPoisson"

# Grid parameters
ComputationalDomain.nCell = 64 4 4
ComputationalDomain.maxGridSize = 8 4 4
ComputationalDomain.isPeriodic = 1 1 1 # 1 -> periodic, 0 -> else
nGhostExtra = 2

# Particle parameters
Particle.speciesNames = electrons
rhoBackground = 1 # one species
Particle.sampler = Sobol
Particle.electrons.nPartPerCell = 1000 # number of particles per cell
Particle.electrons.charge = -1.0 # vector (one entry per species)
Particle.electrons.mass = 1.0 # vector (one entry per species)
Particle.electrons.density = "1.0 + 0.001 * cos(kvarx * x)"
Particle.electrons.numGaussians = 2

# Gaussian parameters
Particle.electrons.G0.vMean = 0.0 0.0 0.0
Particle.electrons.G0.vThermal = 1 1 1
Particle.electrons.G0.vWeight = 0.9
Particle.electrons.G1.vMean = 4.5 0.0 0.0
Particle.electrons.G1.vThermal = 0.5 0.5 0.5
Particle.electrons.G1.vWeight = 0.1

# wave vector
k = 0.3 0.3 0.3

# Simulation parameters
TimeLoop.nSteps = 2000
TimeLoop.dt = 0.02

# Filter
Filter.enable = 1
Filter.type = Bilinear
Filter.nPass = 1 1 1

# Function parameters
Function.Ex = "0.0"
Function.Ey = "0.0"
Function.Ez = "0.0"
Function.Bx = "0.0"
Function.By = "0.0"
Function.Bz = "0.0"

# Diagnostics
#Full Diagnostics 
FullDiagnostics.enable = 1 # 1 for true, 0 for false
FullDiagnostics.groupNames = part field 
FullDiagnostics.part.varNames = electrons
FullDiagnostics.part.saveInterval = 1000
FullDiagnostics.field.varNames = rho Ex phi
FullDiagnostics.field.outputProcessor = CellCenter 
FullDiagnostics.field.saveInterval = 1

# Reduced Diagnostics 
ReducedDiagnostics.enable = 1 # 1 for true, 0 for false
ReducedDiagnostics.groupNames = Part ElecEnergy 
ReducedDiagnostics.saveInterval = 1 # saveInterva
ReducedDiagnostics.ElecEnergy.types = ElecFieldEnergy
ReducedDiagnostics.Part.types = Particle
