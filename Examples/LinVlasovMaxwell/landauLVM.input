# General setting
simName = "LinVlasovMaxwell"

# Grid parameters
ComputationalDomain.nCell = 32 1 1
ComputationalDomain.maxGridSize = 16 1 1
ComputationalDomain.isPeriodic = 1 1 1 # 1 -> periodic, 0 -> else

# Particle parameters
Particle.speciesNames = electrons
Particle.sampler = Sobol
Particle.seed = 123
Particle.electrons.nPartPerCell = 1000 # number of Particles per cell
Particle.electrons.charge = -1.0 # vector (one entry per species)
Particle.electrons.mass = 1.0 # vector (one entry per species)
Particle.electrons.density = "0.04 * cos(kvarx * x)"
Particle.electrons.numGaussians = 1
Particle.electrons.compNames = vx vy vz weight s0 sqrtf0
Particle.electrons.vThermalBackground = 1.0
Particle.electrons.densityBackground = "1.0"

# Gaussian parameters
Particle.electrons.G0.vMean = 0.0 0.0 0.0
Particle.electrons.G0.vThermal = 1 1 1
Particle.electrons.G0.vWeight = 1.0

# wave vector
k = 0.4 6.283185307179586 6.283185307179586

# Simulation parameters
TimeLoop.nSteps = 500
TimeLoop.dt = 0.04

# Function parameters
Function.BBackgroundX = "0"
Function.BBackgroundY = "0"
Function.BBackgroundZ = "0"

PoissonSolver.solver = "Amrex"

# Diagnostics
# Full Diagnostics
FullDiagnostics.enable = 0 # 1 for true, 0 for false
FullDiagnostics.groupNames = field part

FullDiagnostics.part.varNames = electrons
FullDiagnostics.part.saveInterval = 1

FullDiagnostics.field.varNames = Ex
FullDiagnostics.field.outputProcessor = CellCenter 
FullDiagnostics.field.saveInterval = 1

# Reduced Diagnostics
ReducedDiagnostics.enable = 1 # 1 for true, 0 for false
ReducedDiagnostics.groupNames = Part ElecEnergy MagEnergy
ReducedDiagnostics.saveInterval = 1 # saveInterval for all groupings not specifying their own

ReducedDiagnostics.ElecEnergy.types = ElecFieldEnergy
ReducedDiagnostics.MagEnergy.types = MagFieldEnergy

ReducedDiagnostics.Part.types = ParticleLinVlasov